# Anthropic (Claude) API
ANTHROPIC_API_KEY=sk-your-key-here

# OpenAI API (for embeddings)
OPENAI_API_KEY=sk-your-key-here

# Optional: Semantic Scholar API Key (free tier available without key, but key gives higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Optional: PubMed / NCBI API Key (for higher rate limits)
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com

# Optional: Crossref Plus API Token (polite pool works without it)
CROSSREF_EMAIL=your-email@example.com

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Model Configuration
DEFAULT_MODEL=deepseek-v4-pro
LIGHT_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-3-large

# Database
DATABASE_URL=sqlite:///data/research.db
CHROMA_PERSIST_DIR=data/chroma_db
PAPER_CACHE_DIR=data/paper_cache
FIGURES_DIR=data/figures

# Ali Bailian for embedding (DashScope)
DASHSCOPE_API_KEY=sk-your-key-here

# Unpaywall (for PDF download)
UNPAYWALL_EMAIL=your-email@example.com
UNPAYWALL_PROXY=
